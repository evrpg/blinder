# Project verification config — sourced by blinder/init.sh.
#
# PROJECT-OWNED: `blinder upgrade` never overwrites this file. (init.sh itself is
# harness-owned and gets refreshed on upgrade — that's why the tuning lives here.)
#
# Fill these in once you know the real commands for THIS project. When set, a command
# OVERRIDES init.sh's generic auto-detection for that tier — exact and fast instead of
# guessed. Leave empty to keep auto-detection. Agents: keep these accurate as the
# build evolves.
#
#   PROJECT_COMPILE_CMD="./gradlew compileKotlin -q"   # fast tier (runs on every check)
#   PROJECT_TEST_CMD="./gradlew test -q"               # runs only with --full
PROJECT_COMPILE_CMD=""
PROJECT_TEST_CMD=""

# Optional: a second, cross-model review pass. When REVIEWER_CODEX=1 AND the `codex`
# CLI is on PATH, the reviewer runs an independent code-vs-spec audit with Codex (a
# different model) and reconciles its findings — the verdict stays the reviewer's.
# Requires the standalone Codex CLI on PATH (github.com/openai/codex) — the reviewer
# calls `codex exec` from its subagent, NOT the /codex:review slash command.
# Unset/0 = Claude-only review (default; no external dependency).
REVIEWER_CODEX=0
